        "\n",
        "        self.easy_enemy_stop_expand = False\n",
        "        if EASY_ENEMY_STOP_EXPAND_ENABLED and self.step >= EASY_ENEMY_STOP_EXPAND_TURN_MIN:\n",
        "            easy_count = 0\n",
        "            for ep in self.enemy_planets:\n",
        "                if int(ep.ships) > EASY_ENEMY_MAX_GARRISON:\n",
