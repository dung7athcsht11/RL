        "import heuris1 as p1\n",
        "import heuris2 as p2\n",
        "\n",
        "def collect_mdp_data(num_episodes=500, max_steps=500):\n",
        "    dataset = []  # (state, action, reward, next_state, done)\n",
        "    env = make(ENV_NAME)\n",
        "    for ep in tqdm(range(num_episodes), desc=\"MDP Self-Play\"):\n",
        "        states = env.reset()\n",
        "        obs0 = states[0]['observation']\n",
        "        obs1 = states[1]['observation']\n",
        "        done = False\n",
        "        steps = 0\n",
        "        while not done and steps < max_steps:\n",
        "            moves0, phase0 = p1.agent(obs0)   # dùng heuristic\n",
        "            moves1, phase1 = p2.agent(obs1)\n",
        "            state = extract_state(obs0)       # vector 32 chiều\n",
        "            action = phase_to_index(phase0)   # macro 0..7\n",
        "            next_states = env.step([moves0, moves1])\n",
        "            # Xác định reward: +1 nếu thắng, -1 nếu thua, 0 nếu chưa kết thúc\n",
        "            done = (next_states[0]['status'] != 'ACTIVE')\n",
        "            reward = 0.0\n",
        "            if done:\n",
        "                if next_states[0]['reward'] == 1 and next_states[1]['reward'] == -1:\n",
        "                    reward = 1.0   # thắng\n",
        "                elif next_states[0]['reward'] == -1 and next_states[1]['reward'] == 1:\n",
        "                    reward = -1.0  # thua\n",
        "            next_state = extract_state(next_states[0]['observation']) if not done else np.zeros(32)\n",
        "            dataset.append((state, action, reward, next_state, done))\n",
        "            obs0 = next_states[0]['observation']\n",
        "            obs1 = next_states[1]['observation']\n",
        "            steps += 1\n",
        "        if (ep+1) % 100 == 0:\n",
        "            print(f\"Episode {ep+1}: collected {len(dataset)} transitions\")\n",
        "    return dataset"
      ]
    },
