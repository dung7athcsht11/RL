        "\n",
        "    @property\n",
        "    def num_players(self):\n",
        "        owners = set()\n",
        "        for p in self.planets:\n",
        "            if p.owner != -1:\n",
        "                owners.add(p.owner)\n",
        "        for f in self.fleets:\n",
