        "        self.is_2p = (_game_num_players == 2)\n",
        "\n",
        "\n",
        "\n",
        "        if self.is_2p:\n",
        "            COALITION_MIN_PER_CONTRIBUTOR = COALITION_MIN_PER_CONTRIBUTOR_2P\n",
        "            DEFENSE_OVERSEND = DEFENSE_OVERSEND_2P\n",
        "            PSM_OPENING_TURN = PSM_OPENING_TURN_2P\n",
