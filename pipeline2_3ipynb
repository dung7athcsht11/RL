      "source": [
        "import numpy as np\n",
        "import random\n",
        "import math\n",
        "from tqdm.notebook import tqdm\n",
        "from kaggle_environments import make\n",
        "\n",
        "# tính Dense Reward cho CQL\n",
        "def calc_dense_reward(obs_prev, obs_curr, player):\n",
        "    if obs_prev is None or obs_curr is None: return 0.0\n",
        "    def get_stats(obs):\n",
        "        planets = obs.get('planets', [])\n",
        "        my_s = sum(p[5] for p in planets if p[1] == player)\n",
        "        en_s = sum(p[5] for p in planets if p[1] not in (-1, player))\n",
        "        my_pr = sum(p[6] for p in planets if p[1] == player)\n",
        "        en_pr = sum(p[6] for p in planets if p[1] not in (-1, player))\n",
        "        my_pl = sum(1 for p in planets if p[1] == player)\n",
        "        en_pl = sum(1 for p in planets if p[1] not in (-1, player))\n",
        "        return my_s, en_s, my_pr, en_pr, my_pl, en_pl\n",
        "\n",
        "    my_s_p, en_s_p, my_pr_p, en_pr_p, my_pl_p, en_pl_p = get_stats(obs_prev)\n",
        "    my_s_c, en_s_c, my_pr_c, en_pr_c, my_pl_c, en_pl_c = get_stats(obs_curr)\n",
        "\n",
        "    delta_ships = (my_s_c - my_s_p) - (en_s_c - en_s_p)\n",
        "    delta_prod = (my_pr_c - my_pr_p) - (en_pr_c - en_pr_p)\n",
        "    delta_pl = (my_pl_c - my_pl_p) - (en_pl_c - en_pl_p)\n",
        "    return float((delta_ships * 0.01) + (delta_pl * 5.0) + (delta_prod * 8.0))\n",
        "\n",
        "# Map Phase\n",
        "INDEX_TO_PHASE = {0: 'grow', 1: 'expand', 2: 'aggressive', 3: 'dominate', 4: 'counter_attack', 5: 'rush'}\n",
        "\n",
        "#  Vòng lặp thu thập\n",
        "def collect_unified_data(num_episodes=500, epsilon=0.15):\n",
        "    # Buffer cho CQL\n",
        "    cql_states, cql_actions, cql_rewards, cql_dones = [], [], [], []\n",
        "    cql_next_states = []\n",
        "    # Buffer cho ValidShot\n",
        "    shot_features, shot_labels = [], []\n",
        "\n",
        "    env = make(\"orbit_wars\") \n",
        "\n",
        "    for ep in tqdm(range(num_episodes), desc=\"Unified Data Collection\"):\n",
        "        opp = random.choice([\"random\", agent])\n",
        "        trainer = env.train([None, opp])\n",
        "        obs = trainer.reset()\n",
        "        player = obs['player']\n",
        "\n",
        "        done = False\n",
        "        step_count = 0\n",
        "\n",
        "        owner_history = {}\n",
        "        shots_in_game = []\n",
        "\n",
        "        while not done and step_count < 500:\n",
        "            #  QUYẾT ĐỊNH (CÓ KHÁM PHÁ CHO CQL) \n",
        "            expert_moves, expert_phase = agent(obs, config=None, return_phase=True)\n",
        "            macro_id = phase_to_index(expert_phase)\n",
        "\n",
        "            if random.random() < epsilon:\n",
        "                macro_id = random.randint(0, 5)\n",
        "                forced_phase = INDEX_TO_PHASE.get(macro_id, 'grow')\n",
        "                moves = agent(obs, config=None, return_phase=False, forced_phase=forced_phase)\n",
        "            else:\n",
        "                moves = expert_moves\n",
        "\n",
        "            # LƯU TRỮ PHÁT BẮN CHO VALIDATOR\n",
        "            planets = obs['planets']\n",
        "            src_xy = {int(p[0]): (float(p[2]), float(p[3])) for p in planets}\n",
        "\n",
        "            for mv in moves:\n",
        "                src_id, angle, ships = int(mv[0]), float(mv[1]), int(mv[2])\n",
        "                if src_id not in src_xy: continue\n",
        "\n",
        "                tgt_id = find_target_by_ray(src_xy[src_id], angle, planets)\n",
        "                if tgt_id >= 0 and tgt_id != src_id:\n",
        "                    tgt_owner = next((p[1] for p in planets if p[0] == tgt_id), -2)\n",
        "                    #  KHÔNG LẤY CÁC SHOT VIỆN TRỢ CHÍNH MÌNH\n",
        "                    if tgt_owner != player:\n",
        "                        feat = encode_shot(obs, src_id, tgt_id, ships)\n",
        "                        if feat is not None:\n",
        "                            # Tính ETA (số lượt bay)\n",
        "                            src_p = next(p for p in planets if p[0] == src_id)\n",
        "                            tgt_p = next(p for p in planets if p[0] == tgt_id)\n",
        "                            dist_eff = max(0.0, math.hypot(tgt_p[2]-src_p[2], tgt_p[3]-src_p[3]) - src_p[4] - tgt_p[4])\n",
        "                            eta = max(1, int(math.ceil(dist_eff / fleet_speed(ships))))\n",
        "\n",
        "                            shots_in_game.append({\n",
        "                                'turn': step_count, 'eta': eta, 'tgt': tgt_id, 'feat': feat\n",
        "                            })\n",
        "\n",
        "            # LƯU TRỮ STATE VÀ REWARD CHO CQL\n",
        "            state_vector = extract_state(obs)\n",
        "            next_obs, step_reward, done, _ = trainer.step(moves)\n",
        "\n",
        "            dense_r = calc_dense_reward(obs, next_obs, player)\n",
        "            if done:\n",
        "                if step_reward is not None and step_reward > 0: dense_r += 100.0\n",
        "                elif step_reward is not None and step_reward < 0: dense_r -= 100.0\n",
        "\n",
        "            cql_states.append(state_vector)\n",
        "            cql_actions.append(macro_id)\n",
        "            cql_rewards.append(dense_r)\n",
        "            cql_dones.append(1.0 if done else 0.0)\n",
        "            cql_next_states.append(extract_state(next_obs))\n",
        "            # Ghi lại lịch sử sở hữu (Cốt lõi để gán nhãn Validator)\n",
        "            owner_history[step_count] = {int(p[0]): int(p[1]) for p in obs['planets']}\n",
        "\n",
        "            obs = next_obs\n",
        "            step_count += 1\n",
        "\n",
        "        # Lưu turn cuối cùng\n",
        "        if obs is not None:\n",
        "            owner_history[step_count] = {int(p[0]): int(p[1]) for p in obs.get('planets', [])}\n",
        "\n",
        "        # --- PHẦN 4: GÁN NHÃN SHOT VALIDATOR DỰA TRÊN TƯƠNG LAI THỰC TẾ ---\n",
        "        for shot in shots_in_game:\n",
        "            arrival_turn = shot['turn'] + shot['eta']\n",
        "            success = 0.0\n",
        "            # Rule của tác giả: Nhãn = 1 nếu target thuộc về ta ở BẤT KỲ turn nào từ ETA đến ETA+10\n",
        "            for t in range(arrival_turn, min(arrival_turn + 11, step_count + 1)):\n",
        "                if t in owner_history and owner_history[t].get(shot['tgt'], -2) == player:\n",
        "                    success = 1.0\n",
        "                    break\n",
        "\n",
        "            shot_features.append(shot['feat'])\n",
        "            shot_labels.append(success)\n",
        "\n",
        "    return {\n",
        "        'cql': (np.array(cql_states, dtype=np.float32), np.array(cql_actions, dtype=np.int32),\n",
        "                np.array(cql_rewards, dtype=np.float32), np.array(cql_dones, dtype=np.float32), np.array(cql_next_states, dtype=np.float32)),\n",
        "        'shot': (np.array(shot_features, dtype=np.float32), np.array(shot_labels, dtype=np.float32))\n",
        "    }\n",
        "\n",
        "#  Chạy thu thập và lưu\n",
        "print(\"Đang chạy thu thập dữ liệu song song...\")\n",
        "data_dict = collect_unified_data(num_episodes=1000, epsilon=0.2)\n",
        "\n",
        "cql_data = data_dict['cql']\n",
        "np.savez(\"mdp_dataset.npz\", states=cql_data[0], actions=cql_data[1], rewards=cql_data[2], dones=cql_data[3], next_states = cql_data[4])\n",
        "print(f\"Đã lưu {len(cql_data[0])} mẫu cho CQL\")\n",
        "\n",
        "shot_data = data_dict['shot']\n",
        "np.savez(\"shot_data.npz\", X=shot_data[0], y=shot_data[1])\n",
        "print(f\"Đã lưu {len(shot_data[0])} mẫu cho ValidShot (Tỷ lệ Positive: {shot_data[1].mean():.2f})\")"
      ]
    },
