        "        )\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "        self.focus_enemy_2p = None\n",
        "        if F14_4A_2P_FOCUS_ENABLED and self.is_2p:\n",
        "            for o in self.owner_production.keys():\n",
        "                if o not in (-1, self.player):\n",
        "                    self.focus_enemy_2p = o\n",
