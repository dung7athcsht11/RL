        "import numpy as np\n",
        "from d3rlpy.dataset import MDPDataset\n",
        "from d3rlpy.algos import DiscreteCQLConfig \n",
        "\n",
        "# 1. Load và ép kiểu dữ liệu \n",
        "data = np.load(\"mdp_dataset.npz\")\n",
        "states = np.array(data['states'], dtype=np.float32)\n",
        "actions = np.array(data['actions'], dtype=np.int32)\n",
        "rewards = np.array(data['rewards'], dtype=np.float32)\n",
        "terminals = np.array(data['dones'], dtype=np.float32)\n",
        "next_states = np.array(data['next_states'], dtype=np.float32)\n",
        "\n",
        "mdp_dataset = MDPDataset(\n",
        "    observations=states,\n",
        "    actions=actions,\n",
        "    rewards=rewards,\n",
        "    terminals=terminals,\n",
        "    next_observations=next_states\n",
        ")\n",
        "\n",
        "# 2. Khởi tạo thuật toán qua DiscreteCQLConfig\n",
        "cql = DiscreteCQLConfig(\n",
        "    learning_rate=3e-4,\n",
        "    batch_size=256,\n",
        "    gamma=0.99,\n",
        "    alpha=1.0,       \n",
        ").create(device=\"cpu\") \n",
        "\n",
        "# 3. Huấn luyện\n",
        "print(\"Bắt đầu train Offline RL...\")\n",
        "cql.fit(\n",
        "    mdp_dataset,\n",
        "    n_steps=300000,\n",
        "    n_steps_per_epoch=5000,\n",
        "    save_interval=10,\n",
        "    show_progress=True\n",
        ")\n",
        "\n",
        "# 4. Xuất mô hình sang định dạng TorchScript để nộp lên Kaggle\n",
        "cql.build_with_dataset(mdp_dataset)\n",
        "cql.save_policy(\"cql_policy.pt\")\n",
        "print(\"Train xong và đã lưu model TorchScript thành công!\")"
      ]
    },
