        "import multiprocessing as mp\n",
        "from functools import partial\n",
        "\n",
        "# Hàm wrapper để chạy agent trong process con\n",
        "def run_agent(obs, config, return_phase, result_queue):\n",
        "    # Import lại toàn bộ module bot trong process con  # thay bằng tên module chứa agent\n",
        "    moves, phase = agent(obs, config, return_phase)\n",
        "    result_queue.put((moves, phase))\n",
        "\n",
        "def collect_dataset_selfplay(num_episodes=500, max_steps=500):\n",
        "    dataset = []\n",
        "    env = make(\"orbit_wars\")\n",
        "\n",
        "    for ep in tqdm(range(num_episodes), desc=\"Self-Play\"):\n",
        "        states = env.reset()\n",
        "        obs0 = states[0]['observation']\n",
        "        obs1 = states[1]['observation']\n",
        "        done = False\n",
        "        steps = 0\n",
        "\n",
        "        while not done and steps < max_steps:\n",
        "            # Tạo hai process riêng cho mỗi agent\n",
        "            q0, q1 = mp.Queue(), mp.Queue()\n",
        "            p0 = mp.Process(target=run_agent, args=(obs0, None, True, q0))\n",
        "            p1 = mp.Process(target=run_agent, args=(obs1, None, True, q1))\n",
        "            p0.start()\n",
        "            p1.start()\n",
        "            p0.join()\n",
        "            p1.join()\n",
        "            moves0, phase0 = q0.get()\n",
        "            moves1, phase1 = q1.get()\n",
        "\n",
        "            state = extract_state(obs0)\n",
        "            macro = phase_to_index(phase0)\n",
        "            dataset.append((state, macro))\n",
        "\n",
        "            next_states = env.step([moves0, moves1])\n",
        "            states = next_states\n",
        "            obs0 = states[0]['observation']\n",
        "            obs1 = states[1]['observation']\n",
        "            done = (states[0]['status'] != 'ACTIVE') or (states[1]['status'] != 'ACTIVE')\n",
        "            steps += 1\n",
        "\n",
        "        if (ep+1) % 100 == 0:\n",
        "            print(f\"Episode {ep+1}: samples={len(dataset)}\")\n",
        "    return dataset"
      ]
